<% include partials/header %>
<meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="stylesheet" type="text/css" href="public /new.css">
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.4.1/jquery.min.js"></script>
<link rel="stylesheet" type="text/css" href="https://cdnjs.cloudflare.com/ajax/libs/semantic-ui/2.4.1/semantic.min.css">
<style>
header.jumbotron{
	color:white;
	background:black;
}</style>
<header class="jumbotron"><h1>Add Services</h1>
	<br>
<ul><a class="btn btn-primary btn-large" href="/home"><b>Home</b></a>
<a class="btn btn-primary btn-large" href="services"><b>Events</b></a>

<a class="btn btn-primary btn-large" href="/contact"><b>Contact Us</b></a>

<a class="btn btn-primary btn-large" href="/logout"><b>Log out</b></a></ul><br></header>
<div class="container">
<form method="POST" action="/services">
	 <div class="form-group">
	 	<label for="name">Name:</label>
      <input type="text" class="form-control" id="name" placeholder="Enter the Service that can be provided" name="name">
      <label for="location">Location:</label>
      <input type="text" class="form-control" id="location" placeholder="Enter the Venue " name="location">
      <label for="date">Date:</label>
      <input type="date" class="form-control" id="date" placeholder="Held on" name="date">
      <label for="amount">Amount:</label>
      <input type="Number" class="form-control" id="amount" placeholder="Amount sanctioned for that service" name="amount">
      <label for="description">Description:</label>
      <input type="text" class="form-control" id="description" placeholder="Some Description about the service" name="description">
    </div>
<center><button type="Submit" class="btn btn-primary">Submit</button></center>
</form></div>
